{
  "name": "match-centre",
  "version": "1.0.0",
  "description": "Premier League match centre — fixtures, form & predictions",
  "main": "index.js",
  "scripts": {
    "start":             "node index.js",
    "dev":               "node --watch index.js",
    "test":              "node api.test.js",
